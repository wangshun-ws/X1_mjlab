<mujoco model="custom_robot_policy_scene">
  <include file="../src/assets/robots/custom_robot/xmls/custom_robot.xml" />

  <compiler
    angle="radian"
    meshdir="../src/assets/robots/custom_robot/xmls/assets"
    autolimits="true"
    eulerseq="zyx" />

  <asset>
    <texture
      name="groundplane"
      type="2d"
      builtin="checker"
      rgb1="0.2 0.3 0.4"
      rgb2="0.1 0.2 0.3"
      width="300"
      height="300"
      mark="edge"
      markrgb="0.8 0.8 0.8" />
    <material
      name="groundplane"
      texture="groundplane"
      texuniform="true"
      texrepeat="8 8"
      reflectance="0.2" />
  </asset>

  <worldbody>
    <light name="sun" pos="0 0 3" dir="0 0 -1" directional="true" castshadow="true" />
    <geom
      name="terrain"
      type="plane"
      size="20 20 0.1"
      material="groundplane"
      contype="1"
      conaffinity="1"
      friction="1.0 0.2 0.2" />
  </worldbody>

  <actuator>
    <motor name="left_hip_yaw_joint_motor" joint="left_hip_yaw_joint" ctrlrange="-80 80" />
    <motor name="left_hip_roll_joint_motor" joint="left_hip_roll_joint" ctrlrange="-120 120" />
    <motor name="left_hip_pitch_joint_motor" joint="left_hip_pitch_joint" ctrlrange="-212 212" />
    <motor name="left_knee_joint_motor" joint="left_knee_joint" ctrlrange="-180 180" />
    <motor name="left_ankle_pitch_joint_motor" joint="left_ankle_pitch_joint" ctrlrange="-80 80" />
    <motor name="left_ankle_roll_joint_motor" joint="left_ankle_roll_joint" ctrlrange="-20 20" />
    <motor name="right_hip_yaw_joint_motor" joint="right_hip_yaw_joint" ctrlrange="-80 80" />
    <motor name="right_hip_roll_joint_motor" joint="right_hip_roll_joint" ctrlrange="-120 120" />
    <motor name="right_hip_pitch_joint_motor" joint="right_hip_pitch_joint" ctrlrange="-212 212" />
    <motor name="right_knee_joint_motor" joint="right_knee_joint" ctrlrange="-180 180" />
    <motor name="right_ankle_pitch_joint_motor" joint="right_ankle_pitch_joint" ctrlrange="-80 80" />
    <motor name="right_ankle_roll_joint_motor" joint="right_ankle_roll_joint" ctrlrange="-20 20" />
  </actuator>
</mujoco>
